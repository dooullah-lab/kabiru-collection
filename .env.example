# ---- Supabase (your product database) ----
# Find these in Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Paystack (taking payments) ----
# Find these in Paystack: Settings -> API Keys & Webhooks
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx

# ---- Admin login ----
# This is the password YOU will type in to reach the admin dashboard. Make it up yourself.
ADMIN_PASSWORD=change-this-password
